---
import { SUPPORTED_FORMATS, QUALITY_RANGE, WIDTH_CANDIDATES, DEFAULT_QUALITY } from "../lib/convert";

export interface Props {
  image: { src?: string; alt?: string };
  sizes?: string;
  format?: string;
  quality?: number;
  class?: string;
  loading?: "lazy" | "eager";
  decoding?: "async" | "sync" | "auto";
  preload?: boolean;
}

const {
  image,
  sizes = "100vw",
  format = "webp",
  quality = DEFAULT_QUALITY,
  class: className,
  loading = "lazy",
  decoding = "async",
  preload = false,
} = Astro.props;

const isExternal = image.src?.startsWith("http://") || image.src?.startsWith("https://");
const mediaMatch = image.src?.match(/\/_emdash\/(?:api\/)?media\/file\/(.+)/);
const storageKey = isExternal ? null : mediaMatch?.[1] || null;

const imageBase = "/image";

if (isExternal || !storageKey) {
  <img src={image.src || ""} alt={image.alt || ""} />
} else {
  const allowedFormats = new Set<string>(SUPPORTED_FORMATS);
  const validatedFormat = allowedFormats.has(format) ? format : "webp";
  const clampedQuality = Math.max(QUALITY_RANGE.min, Math.min(QUALITY_RANGE.max, quality));
  const baseUrl = `${imageBase}/${storageKey}?format=${validatedFormat}&q=${clampedQuality}`;
  const src = `${baseUrl}&w=960`;
  const srcset = WIDTH_CANDIDATES.map((w) => `${baseUrl}&w=${w} ${w}w`).join(",\n");

  if (preload) {
    <link rel="preload" as="image" href={src} imagesrcset={srcset} imagesizes={sizes} type={`image/${validatedFormat}`} />
  }

  <img src={src} alt={image.alt || ""} srcset={srcset} sizes={sizes} loading={loading} decoding={decoding} class={className} />
}
